{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@myra/shared": ["../shared/src/index.ts"],
      "@myra/shared/*": ["../shared/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/cf", "src/core/auth.ts", "src/core/credential-store.ts"]
}
