{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@myra/shared": ["../shared/src/index.ts"],
      "@myra/shared/*": ["../shared/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src"]
}
