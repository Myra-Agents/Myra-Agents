{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Myra Agents",
  "version": "0.3.1",
  "identifier": "com.myra-agents.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run sidecar:build && npm run dev",
    "beforeBuildCommand": "npm run sidecar:build && npm run build"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["myra"]
      }
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Myra Agents",
        "width": 1400,
        "height": 900,
        "minWidth": 640,
        "minHeight": 500,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 22 },
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/myra-server"],
    "resources": ["Assets.car"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": "./dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
