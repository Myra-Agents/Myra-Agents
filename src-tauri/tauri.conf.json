{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Myra Agents",
  "version": "1.0.0",
  "identifier": "com.myra-agents.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run sidecar:build && npm run dev",
    "beforeBuildCommand": "npm run sidecar:build && npm run build"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["myra"]
      }
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Myra Agents",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": ["binaries/myra-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
