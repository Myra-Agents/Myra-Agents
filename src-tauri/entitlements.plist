<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened Runtime entitlements. Required so a Developer ID build can be
	     notarized by Apple and still run the things this app needs:
	       - WKWebView JIT-compiles JS, so allow-jit is mandatory.
	       - We bundle the `myra-server` sidecar (externalBin, re-signed at bundle
	         time) and shell out to user-configured agent CLIs; disabling library
	         validation lets the app load/exec binaries not signed by our team. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
